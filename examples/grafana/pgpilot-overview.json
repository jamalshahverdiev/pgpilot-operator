{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Starter dashboard for pgpilot-operator \u2014 visualizes the pgwatch_* metrics produced by PgpilotMonitor pods. Designed to light up under the stress scenarios shipped in hack/testdb/stress/.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Total database size per monitored instance.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_db_size_size_b{dbname=~\"$dbname\"}",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "DB size",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Idle-in-transaction connections across all monitored DBs. Anything above 0 for more than a few seconds indicates a leaking client or a forgotten BEGIN.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_idleintransaction{dbname=~\"$dbname\"}",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "Idle in transaction",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Age (in transactions) of the oldest xmin pinned on this database. Growing values indicate something is holding a snapshot \u2014 blocks VACUUM and eventually triggers xid wraparound risk.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 100000
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_max_xmin_age_tx{dbname=~\"$dbname\"}",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "Max xmin age (xid wraparound risk)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cumulative deadlocks since DB start. A flat line is good; any increase means concurrent writers are colliding.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_db_stats_deadlocks{dbname=~\"$dbname\"}",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "Deadlocks",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 200,
      "title": "Backends & Locks",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Connection state breakdown over time.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_active{dbname=~\"$dbname\"}",
          "legendFormat": "active {{dbname}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_idle{dbname=~\"$dbname\"}",
          "legendFormat": "idle {{dbname}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_idleintransaction{dbname=~\"$dbname\"}",
          "legendFormat": "idle-in-tx {{dbname}}",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_backends_waiting{dbname=~\"$dbname\"}",
          "legendFormat": "waiting {{dbname}}",
          "refId": "D"
        }
      ],
      "title": "Backend states",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Lock counts grouped by lock type.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (dbname, locktype) (pgwatch_locks_count{dbname=~\"$dbname\"})",
          "legendFormat": "{{dbname}} {{locktype}}",
          "refId": "A"
        }
      ],
      "title": "Locks by type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 300,
      "title": "Tables & Bloat",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "seq_scan rate per table. Tables with high seq_scan and no accompanying idx_scan usually have a missing index. Uses a 15-minute rate window because pgwatch's table_stats metric has a 300s (5 min) collection interval \u2014 a tighter window wouldn't have enough samples for rate().",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(pgwatch_table_stats_seq_scan{dbname=~\"$dbname\"}[15m])",
          "legendFormat": "{{dbname}} / {{table_name}}",
          "refId": "A"
        }
      ],
      "title": "seq_scan rate per table (per second)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Dead tuples per table. Climbs when autovacuum is disabled or can't keep up with update churn.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "pgwatch_table_stats_n_dead_tup{dbname=~\"$dbname\"}",
          "legendFormat": "{{dbname}} / {{table_name}}",
          "refId": "A"
        }
      ],
      "title": "Dead tuples per table",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Approximate table bloat percentage as reported by pgwatch's table_bloat_approx_summary_sql. Collected every 2h by default in the `exhaustive` preset \u2014 this query uses max_over_time so the last value stays visible between collections. To see updates faster in dev, override the interval via a custom metric in your PgpilotMonitor spec.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "id": 9,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max_over_time(pgwatch_table_bloat_approx_summary_sql_approx_bloat_percentage{dbname=~\"$dbname\"}[3h])",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "Approx bloat %",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Indexes that have never been scanned since the last stats reset \u2014 candidates for DROP INDEX. Uses max_over_time over 30 min to stabilize across pgwatch's 15-min index_stats interval.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "id": 10,
      "options": {
        "showHeader": true
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max_over_time(pgwatch_index_stats_idx_scan{dbname=~\"$dbname\"}[30m]) == 0",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Unused indexes (idx_scan == 0)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "exported_instance": true,
              "container": true,
              "endpoint": true,
              "namespace": true,
              "pod": true,
              "service": true,
              "env": true,
              "sys_id": true,
              "index_def_hash": true,
              "schema": true,
              "table_full_name": true,
              "index_full_name": true
            },
            "indexByName": {
              "dbname": 0,
              "table_name": 1,
              "index_name": 2,
              "Value": 3
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "id": 400,
      "title": "Query performance",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Top queries by total cumulative execution time. pgwatch truncates query text to the first 8k chars.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 11,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "total_time"
          }
        ]
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "topk(10, pgwatch_stat_statements_total_time{dbname=~\"$dbname\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Top 10 slowest queries (cumulative total_time, ms)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "exported_instance": true,
              "container": true,
              "endpoint": true,
              "namespace": true,
              "pod": true,
              "service": true,
              "env": true,
              "sys_id": true,
              "queryid": true
            },
            "indexByName": {
              "dbname": 0,
              "query": 1,
              "Value": 2
            },
            "renameByName": {
              "Value": "total_time"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "id": 500,
      "title": "WAL & I/O",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "WAL generation rate \u2014 bytes per second. Useful for tuning replication bandwidth and archiver throughput.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "id": 12,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(pgwatch_wal_xlog_location_b{dbname=~\"$dbname\"}[5m])",
          "legendFormat": "{{dbname}}",
          "refId": "A"
        }
      ],
      "title": "WAL generation rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Checkpoint activity. A healthy DB does mostly timed checkpoints; a growing requested rate indicates checkpoint pressure.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 45
      },
      "id": 13,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "12.4.3",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(pgwatch_bgwriter_checkpoints_timed{dbname=~\"$dbname\"}[5m])",
          "legendFormat": "timed {{dbname}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "rate(pgwatch_bgwriter_checkpoints_req{dbname=~\"$dbname\"}[5m])",
          "legendFormat": "requested {{dbname}}",
          "refId": "B"
        }
      ],
      "title": "Checkpoint rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": [
